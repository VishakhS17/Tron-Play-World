generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model addresses {
  id                                           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id                                  String?  @db.Uuid
  full_name                                    String   @db.VarChar(150)
  phone                                        String   @db.VarChar(30)
  line1                                        String   @db.VarChar(255)
  line2                                        String?  @db.VarChar(255)
  city                                         String   @db.VarChar(120)
  state                                        String   @db.VarChar(120)
  postal_code                                  String   @db.VarChar(20)
  country                                      String   @db.VarChar(80)
  is_default_billing                           Boolean  @default(false)
  is_default_shipping                          Boolean  @default(false)
  created_at                                   DateTime @default(now()) @db.Timestamptz(6)
  updated_at                                   DateTime @default(now()) @db.Timestamptz(6)
  customers                                    customers? @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  orders_orders_billing_address_idToaddresses  orders[] @relation("orders_billing_address_idToaddresses")
  orders_orders_shipping_address_idToaddresses orders[] @relation("orders_shipping_address_idToaddresses")

  @@index([customer_id], map: "idx_addresses_customer_id")
}

model admin_users {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String   @unique @db.Citext
  password_hash String
  name          String?  @db.VarChar(150)
  phone         String?  @db.VarChar(30)
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  updated_at    DateTime @default(now()) @db.Timestamptz(6)

  admin_user_roles admin_user_roles[]
  audit_logs       audit_logs[]
}

model audit_logs {
  id            BigInt      @id @default(autoincrement())
  customer_id   String?     @db.Uuid
  admin_user_id String?     @db.Uuid
  entity_type   String      @db.VarChar(80)
  entity_id     String?     @db.Uuid
  action        String      @db.VarChar(80)
  old_values    Json?
  new_values    Json?
  ip_address    String?     @db.Inet
  user_agent    String?
  created_at    DateTime    @default(now()) @db.Timestamptz(6)
  customers     customers?  @relation(fields: [customer_id], references: [id], onUpdate: NoAction)
  admin_users   admin_users? @relation(fields: [admin_user_id], references: [id], onUpdate: NoAction)

  @@index([entity_type, entity_id], map: "idx_audit_entity")
  @@index([customer_id], map: "idx_audit_customer")
  @@index([admin_user_id], map: "idx_audit_admin_user")
}

model brands {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String     @db.VarChar(120)
  slug        String     @unique @db.VarChar(160)
  description String?
  created_at  DateTime   @default(now()) @db.Timestamptz(6)
  updated_at  DateTime   @default(now()) @db.Timestamptz(6)
  products    products[]
  homepage_highlights homepage_highlights[]
  homepage_brand_rail homepage_brand_rail[]
}

/// Diecast model scales (e.g. 1:64). Products reference this like category/brand.
model diecast_scales {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ratio      String     @unique @db.VarChar(10)
  name       String     @db.VarChar(80)
  created_at DateTime   @default(now()) @db.Timestamptz(6)
  updated_at DateTime   @default(now()) @updatedAt @db.Timestamptz(6)
  products   products[]

  @@index([ratio], map: "idx_diecast_scales_ratio")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model cart_items {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cart_id            String            @db.Uuid
  product_id         String            @db.Uuid
  product_variant_id String?           @db.Uuid
  quantity           Int
  unit_price         Decimal           @db.Decimal(10, 2)
  created_at         DateTime          @default(now()) @db.Timestamptz(6)
  updated_at         DateTime          @default(now()) @db.Timestamptz(6)
  carts              carts             @relation(fields: [cart_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products           products          @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  product_variants   product_variants? @relation(fields: [product_variant_id], references: [id], onUpdate: NoAction)

  @@index([cart_id], map: "idx_cart_items_cart_id")
}

model carts {
  id                         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id                String?      @db.Uuid
  guest_token                String?      @db.Uuid
  status                     String       @default("ACTIVE") @db.VarChar(30)
  abandoned_reminder_sent_at DateTime?    @db.Timestamptz(6)
  created_at                 DateTime     @default(now()) @db.Timestamptz(6)
  updated_at                 DateTime     @default(now()) @db.Timestamptz(6)
  cart_items                 cart_items[]
  customers                  customers?   @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model categories {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String       @db.VarChar(120)
  slug             String       @unique @db.VarChar(160)
  description      String?
  parent_id        String?      @db.Uuid
  created_at       DateTime     @default(now()) @db.Timestamptz(6)
  updated_at       DateTime     @default(now()) @db.Timestamptz(6)
  categories       categories?  @relation("categoriesTocategories", fields: [parent_id], references: [id], onUpdate: NoAction)
  other_categories categories[] @relation("categoriesTocategories")
  products         products[]
  coupon_categories coupon_categories[]
  homepage_highlights homepage_highlights[]
  homepage_category_tiles homepage_category_tiles[]
  product_types     product_types[]

  @@index([parent_id], map: "idx_categories_parent_id")
}

/// Per-category product type (e.g. "RC Car"). Slug is globally unique for simple URL params.
model product_types {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  category_id String  @db.Uuid
  name       String   @db.VarChar(120)
  slug       String   @unique @db.VarChar(160)
  is_active  Boolean  @default(true)
  sort_order Int      @default(0)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
  categories categories @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  product_subtypes product_subtypes[]
  products   products[]

  @@index([category_id], map: "idx_product_types_category_id")
  @@index([is_active], map: "idx_product_types_is_active")
}

/// Subtype of a product type. Slug is globally unique.
model product_subtypes {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_type_id String   @db.Uuid
  name            String   @db.VarChar(120)
  slug            String   @unique @db.VarChar(160)
  is_active       Boolean  @default(true)
  sort_order      Int      @default(0)
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at      DateTime @default(now()) @db.Timestamptz(6)
  product_types   product_types @relation(fields: [product_type_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products        products[]

  @@index([product_type_id], map: "idx_product_subtypes_type_id")
  @@index([is_active], map: "idx_product_subtypes_is_active")
}

/// Optional merchandising collection (e.g. "Summer Sale"). Slug is globally unique.
model product_collections {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String   @db.VarChar(120)
  slug       String   @unique @db.VarChar(160)
  is_active  Boolean  @default(true)
  sort_order Int      @default(0)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)
  products   products[]

  @@index([is_active], map: "idx_product_collections_is_active")
}

model coupon_usages {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  coupon_id   String     @db.Uuid
  customer_id String?    @db.Uuid
  order_id    String?    @db.Uuid
  used_at     DateTime   @default(now()) @db.Timestamptz(6)
  coupons     coupons    @relation(fields: [coupon_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  orders      orders?    @relation(fields: [order_id], references: [id], onUpdate: NoAction)
  customers   customers? @relation(fields: [customer_id], references: [id], onUpdate: NoAction)
}

model coupons {
  id                  String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                String          @unique @db.VarChar(80)
  description         String?
  discount_type       String          @db.VarChar(30)
  discount_value      Decimal         @db.Decimal(10, 2)
  min_cart_value      Decimal?        @db.Decimal(10, 2)
  max_discount_value  Decimal?        @db.Decimal(10, 2)
  starts_at           DateTime?       @db.Timestamptz(6)
  ends_at             DateTime?       @db.Timestamptz(6)
  max_uses            Int?
  max_uses_per_user   Int?
  is_active           Boolean         @default(true)
  applies_to_shipping Boolean         @default(false)
  created_at          DateTime        @default(now()) @db.Timestamptz(6)
  updated_at          DateTime        @default(now()) @db.Timestamptz(6)
  coupon_usages       coupon_usages[]
  orders              orders[]
  coupon_categories   coupon_categories[]
}

/// When rows exist, every cart line product must belong to one of these categories.
model coupon_categories {
  coupon_id   String     @db.Uuid
  category_id String     @db.Uuid
  coupons     coupons    @relation(fields: [coupon_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  categories  categories @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([coupon_id, category_id])
  @@index([category_id], map: "idx_coupon_categories_category_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model inventory {
  id                  String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id          String            @db.Uuid
  product_variant_id  String?           @db.Uuid
  available_quantity  Int               @default(0)
  reserved_quantity   Int               @default(0)
  sold_quantity       Int               @default(0)
  low_stock_threshold Int               @default(0)
  low_stock_alert_sent_at DateTime?     @db.Timestamptz(6)
  updated_at          DateTime          @default(now()) @db.Timestamptz(6)
  products            products          @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  product_variants    product_variants? @relation(fields: [product_variant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([product_id, product_variant_id])
  @@index([available_quantity], map: "idx_inventory_available")
  @@index([available_quantity, low_stock_threshold], map: "idx_inventory_low_stock")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model inventory_reservations {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id           String            @db.Uuid
  order_item_id      String            @db.Uuid
  product_id         String            @db.Uuid
  product_variant_id String?           @db.Uuid
  quantity           Int
  created_at         DateTime          @default(now()) @db.Timestamptz(6)
  released_at        DateTime?         @db.Timestamptz(6)
  orders             orders            @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  order_items        order_items       @relation(fields: [order_item_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products           products          @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  product_variants   product_variants? @relation(fields: [product_variant_id], references: [id], onUpdate: NoAction)

  @@index([order_id], map: "idx_reservations_order_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model order_items {
  id                     String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id               String                   @db.Uuid
  product_id             String                   @db.Uuid
  product_variant_id     String?                  @db.Uuid
  product_name           String                   @db.VarChar(255)
  sku                    String?                  @db.VarChar(120)
  unit_price             Decimal                  @db.Decimal(10, 2)
  quantity               Int
  subtotal_amount        Decimal                  @db.Decimal(10, 2)
  created_at             DateTime                 @default(now()) @db.Timestamptz(6)
  inventory_reservations inventory_reservations[]
  orders                 orders                   @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products               products                 @relation(fields: [product_id], references: [id], onUpdate: NoAction)
  product_variants       product_variants?        @relation(fields: [product_variant_id], references: [id], onUpdate: NoAction)
  returns                returns[]
  reviews                reviews[]

  @@index([order_id], map: "idx_order_items_order_id")
}

model orders {
  id                                              String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id                                     String?                  @db.Uuid
  status                                          order_status_type        @default(PENDING)
  payment_status                                  payment_status_type      @default(PENDING)
  subtotal_amount                                 Decimal                  @db.Decimal(10, 2)
  discount_amount                                 Decimal                  @default(0) @db.Decimal(10, 2)
  shipping_amount                                 Decimal                  @default(0) @db.Decimal(10, 2)
  tax_amount                                      Decimal                  @default(0) @db.Decimal(10, 2)
  total_amount                                    Decimal                  @db.Decimal(10, 2)
  currency                                        String                   @default("INR") @db.Char(3)
  coupon_id                                       String?                  @db.Uuid
  shipping_address_id                             String?                  @db.Uuid
  billing_address_id                              String?                  @db.Uuid
  external_payment_id                             String?                  @db.VarChar(255)
  payment_provider                                String?                  @db.VarChar(80)
  is_gift                                         Boolean                  @default(false)
  gift_message                                    String?
  created_at                                      DateTime                 @default(now()) @db.Timestamptz(6)
  updated_at                                      DateTime                 @default(now()) @db.Timestamptz(6)
  coupon_usages                                   coupon_usages[]
  inventory_reservations                          inventory_reservations[]
  order_items                                     order_items[]
  addresses_orders_billing_address_idToaddresses  addresses?               @relation("orders_billing_address_idToaddresses", fields: [billing_address_id], references: [id], onUpdate: NoAction)
  coupons                                         coupons?                 @relation(fields: [coupon_id], references: [id], onUpdate: NoAction)
  addresses_orders_shipping_address_idToaddresses addresses?               @relation("orders_shipping_address_idToaddresses", fields: [shipping_address_id], references: [id], onUpdate: NoAction)
  customers                                       customers?                 @relation(fields: [customer_id], references: [id], onUpdate: NoAction)
  returns                                         returns[]
  shipments                                       shipments?

  @@index([created_at], map: "idx_orders_created_at")
  @@index([status], map: "idx_orders_status")
  @@index([customer_id], map: "idx_orders_customer_id")
}

model product_images {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id         String?           @db.Uuid
  product_variant_id String?           @db.Uuid
  url                String
  alt_text           String?           @db.VarChar(255)
  sort_order         Int               @default(0)
  created_at         DateTime          @default(now()) @db.Timestamptz(6)
  products           products?         @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  product_variants   product_variants? @relation(fields: [product_variant_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([product_id], map: "idx_product_images_product_id")
  @@index([product_variant_id], map: "idx_product_images_variant_id")
}

model product_variants {
  id                        String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id                String                   @db.Uuid
  name                      String?                  @db.VarChar(255)
  sku                       String?                  @db.VarChar(120)
  color                     String?                  @db.VarChar(80)
  size                      String?                  @db.VarChar(80)
  additional_data           Json?
  price_override            Decimal?                 @db.Decimal(10, 2)
  discounted_price_override Decimal?                 @db.Decimal(10, 2)
  is_default                Boolean                  @default(false)
  created_at                DateTime                 @default(now()) @db.Timestamptz(6)
  updated_at                DateTime                 @default(now()) @db.Timestamptz(6)
  cart_items                cart_items[]
  inventory                 inventory[]
  inventory_reservations    inventory_reservations[]
  order_items               order_items[]
  product_images            product_images[]
  products                  products                 @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([product_id], map: "idx_variants_product_id")
  @@index([sku], map: "idx_variants_sku")
}

model products {
  id                     String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                   String                   @db.VarChar(255)
  slug                   String                   @unique @db.VarChar(255)
  short_description      String?
  description            String?
  age_group              String?                  @db.VarChar(50)
  base_price             Decimal                  @db.Decimal(10, 2)
  discounted_price       Decimal?                 @db.Decimal(10, 2)
  /// INR added to order shipping per unit sold (qty × rate). If cart sum is 0 and subtotal is below the free-shipping threshold, flat default applies.
  shipping_per_unit      Decimal                  @default(0) @db.Decimal(10, 2)
  /// Maximum quantity allowed per order line item for this product.
  max_order_quantity     Int                      @default(99)
  sku                    String?                  @db.VarChar(100)
  /// GST HSN for shipping / invoicing (digits; optional comma for multiple codes on one SKU)
  hsn_code               String?                  @db.VarChar(32)
  diecast_scale_id       String?                  @db.Uuid
  category_id            String?                  @db.Uuid
  type_id                String?                  @db.Uuid
  subtype_id             String?                  @db.Uuid
  collection_id          String?                  @db.Uuid
  brand_id               String?                  @db.Uuid
  is_active              Boolean                  @default(true)
  created_at             DateTime                 @default(now()) @db.Timestamptz(6)
  updated_at             DateTime                 @default(now()) @db.Timestamptz(6)
  search_vector          Unsupported("tsvector")?
  cart_items             cart_items[]
  inventory              inventory[]
  inventory_reservations inventory_reservations[]
  order_items            order_items[]
  product_images         product_images[]
  product_variants       product_variants[]
  brands                 brands?                  @relation(fields: [brand_id], references: [id], onUpdate: NoAction)
  diecast_scales         diecast_scales?          @relation(fields: [diecast_scale_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  categories             categories?              @relation(fields: [category_id], references: [id], onUpdate: NoAction)
  product_types          product_types?           @relation(fields: [type_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  product_subtypes       product_subtypes?         @relation(fields: [subtype_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  product_collections    product_collections?     @relation(fields: [collection_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  reviews                reviews[]
  wishlist_items         wishlist_items[]
  homepage_highlights    homepage_highlights[]
  flash_sale_products    flash_sale_products?

  @@index([age_group], map: "idx_products_age_group")
  @@index([brand_id], map: "idx_products_brand_id")
  @@index([diecast_scale_id], map: "idx_products_diecast_scale_id")
  @@index([category_id], map: "idx_products_category_id")
  @@index([type_id], map: "idx_products_type_id")
  @@index([subtype_id], map: "idx_products_subtype_id")
  @@index([collection_id], map: "idx_products_collection_id")
  @@index([is_active], map: "idx_products_is_active")
  @@index([search_vector], map: "idx_products_search_vector", type: Gin)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model returns {
  id            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id      String             @db.Uuid
  order_item_id String             @db.Uuid
  customer_id   String?            @db.Uuid
  quantity      Int
  reason        String?
  status        return_status_type @default(REQUESTED)
  requested_at  DateTime           @default(now()) @db.Timestamptz(6)
  processed_at  DateTime?          @db.Timestamptz(6)
  refund_amount Decimal?           @db.Decimal(10, 2)
  created_at    DateTime           @default(now()) @db.Timestamptz(6)
  orders        orders             @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  order_items   order_items        @relation(fields: [order_item_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  customers     customers?         @relation(fields: [customer_id], references: [id], onUpdate: NoAction)

  @@index([order_id], map: "idx_returns_order_id")
  @@index([status], map: "idx_returns_status")
  @@index([customer_id], map: "idx_returns_customer_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model reviews {
  id                   String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id           String     @db.Uuid
  customer_id          String?    @db.Uuid
  order_item_id        String?    @unique @db.Uuid
  rating               Int
  title                String?    @db.VarChar(255)
  comment              String?
  is_verified_purchase Boolean    @default(false)
  is_approved          Boolean    @default(false)
  created_at           DateTime   @default(now()) @db.Timestamptz(6)
  updated_at           DateTime   @default(now()) @db.Timestamptz(6)
  products             products   @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  customers            customers? @relation(fields: [customer_id], references: [id], onUpdate: NoAction)
  order_items          order_items? @relation(fields: [order_item_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([is_approved], map: "idx_reviews_is_approved")
  @@index([product_id], map: "idx_reviews_product_id")
  @@index([customer_id], map: "idx_reviews_customer_id")
}

model roles {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             admin_role_type    @unique
  description      String?
  admin_user_roles admin_user_roles[]
}

model shipments {
  id              String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id        String               @unique @db.Uuid
  tracking_number String?              @db.VarChar(255)
  carrier         String?              @db.VarChar(120)
  status          shipment_status_type @default(PENDING)
  shipped_at      DateTime?            @db.Timestamptz(6)
  delivered_at    DateTime?            @db.Timestamptz(6)
  metadata        Json?
  created_at      DateTime             @default(now()) @db.Timestamptz(6)
  updated_at      DateTime             @default(now()) @db.Timestamptz(6)
  orders          orders               @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([status], map: "idx_shipments_status")
}

model admin_user_roles {
  admin_user_id String      @db.Uuid
  role_id       String      @db.Uuid
  roles         roles       @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  admin_users   admin_users @relation(fields: [admin_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([admin_user_id, role_id])
}

model customers {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email             String              @unique @db.Citext
  password_hash     String
  google_sub        String?             @unique @db.VarChar(255)
  name              String?             @db.VarChar(150)
  phone             String?             @db.VarChar(30)
  is_active         Boolean             @default(true)
  created_at        DateTime            @default(now()) @db.Timestamptz(6)
  updated_at        DateTime            @default(now()) @db.Timestamptz(6)
  addresses         addresses[]
  audit_logs        audit_logs[]
  carts             carts[]
  coupon_usages     coupon_usages[]
  orders            orders[]
  returns           returns[]
  reviews           reviews[]
  wishlists         wishlists?
  signup_email_otps              signup_email_otps[]
  customer_password_setup_tokens customer_password_setup_tokens[]
}

/// One-time link for checkout-created accounts to set a real password (token stored as SHA-256 hex).
model customer_password_setup_tokens {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id String    @db.Uuid
  token_hash  String    @db.VarChar(64)
  expires_at  DateTime  @db.Timestamptz(6)
  used_at     DateTime? @db.Timestamptz(6)
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  customers   customers @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([token_hash], map: "idx_password_setup_token_hash")
  @@index([customer_id], map: "idx_password_setup_customer_id")
}

// OTP verification for customer signup (email)
model signup_email_otps {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id String    @db.Uuid
  email       String    @db.Citext
  code_hash   String    @db.VarChar(255)
  expires_at  DateTime  @db.Timestamptz(6)
  used_at     DateTime? @db.Timestamptz(6)
  attempts    Int       @default(0)
  created_at  DateTime  @default(now()) @db.Timestamptz(6)

  customers customers @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([email])
  @@index([expires_at])
}

model wishlist_items {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  wishlist_id String    @db.Uuid
  product_id  String    @db.Uuid
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  products    products  @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  wishlists   wishlists @relation(fields: [wishlist_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([wishlist_id, product_id])
}

model wishlists {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customer_id    String           @unique @db.Uuid
  created_at     DateTime         @default(now()) @db.Timestamptz(6)
  wishlist_items wishlist_items[]
  customers      customers        @relation(fields: [customer_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

enum order_status_type {
  PENDING
  PAYMENT_FAILED
  CONFIRMED
  CANCELLED
  SHIPPED
  DELIVERED
  RETURN_REQUESTED
  RETURN_APPROVED
  RETURN_REJECTED
  REFUNDED
}

enum payment_status_type {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum return_status_type {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
}

enum shipment_status_type {
  PENDING
  CREATED
  IN_TRANSIT
  DELIVERED
  DELAYED
  RETURNED
}

enum admin_role_type {
  SUPER_ADMIN
  MANAGER
  STAFF
  SUPPORT
}

enum homepage_highlight_kind {
  FEATURED
  TRENDING
  CATEGORY
  PRODUCT
  BRAND
  CUSTOM
}

enum announcement_placement {
  UTILITY
  MARQUEE
}

enum marketing_popup_frequency {
  ONCE_PER_SESSION
  ONCE_PER_DEVICE
  EVERY_VISIT
}

enum marketing_popup_audience {
  ALL
  GUESTS_ONLY
  LOGGED_IN_ONLY
}

model homepage_hero_slides {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  image_url    String
  image_public_id String? @db.VarChar(255)
  title        String?   @db.VarChar(255)
  link_url     String?
  sort_order   Int       @default(0)
  is_active    Boolean   @default(true)
  active_from  DateTime? @db.Timestamptz(6)
  active_until DateTime? @db.Timestamptz(6)
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  updated_at   DateTime  @default(now()) @db.Timestamptz(6)
}

model homepage_highlights {
  id           String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kind         homepage_highlight_kind
  category_id  String?                @db.Uuid
  product_id   String?                @db.Uuid
  brand_id     String?                @db.Uuid
  title        String                 @db.VarChar(255)
  subtitle     String?
  image_url    String?
  image_public_id String?             @db.VarChar(255)
  link_url     String?
  sort_order   Int                    @default(0)
  is_active    Boolean                @default(true)
  active_from  DateTime?              @db.Timestamptz(6)
  active_until DateTime?              @db.Timestamptz(6)
  created_at   DateTime               @default(now()) @db.Timestamptz(6)
  updated_at   DateTime               @default(now()) @db.Timestamptz(6)
  categories   categories?            @relation(fields: [category_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  products     products?              @relation(fields: [product_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  brands       brands?                @relation(fields: [brand_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([category_id], map: "idx_homepage_highlights_category_id")
  @@index([product_id], map: "idx_homepage_highlights_product_id")
  @@index([brand_id], map: "idx_homepage_highlights_brand_id")
}

/// Homepage horizontal “Shop by brand” tiles (image + label, links to brand filter).
model homepage_brand_rail {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  brand_id        String    @db.Uuid
  image_url       String
  image_public_id String?   @db.VarChar(255)
  label_override  String?   @db.VarChar(120)
  sort_order      Int       @default(0)
  is_active       Boolean   @default(true)
  active_from     DateTime? @db.Timestamptz(6)
  active_until    DateTime? @db.Timestamptz(6)
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  updated_at      DateTime  @default(now()) @db.Timestamptz(6)
  brands          brands    @relation(fields: [brand_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([brand_id], map: "idx_homepage_brand_rail_brand_id")
}

/// Homepage “Discover by category” grid: pick categories, image per tile, order.
model homepage_category_tiles {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  category_id     String     @unique @db.Uuid
  image_url       String
  image_public_id String?    @db.VarChar(255)
  label_override  String?    @db.VarChar(120)
  sort_order      Int        @default(0)
  is_active       Boolean    @default(true)
  active_from     DateTime?  @db.Timestamptz(6)
  active_until    DateTime?  @db.Timestamptz(6)
  created_at      DateTime   @default(now()) @db.Timestamptz(6)
  updated_at      DateTime   @default(now()) @updatedAt @db.Timestamptz(6)
  categories      categories @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([category_id], map: "idx_homepage_category_tiles_category_id")
}

model announcement_entries {
  id           String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  placement    announcement_placement
  body         String
  link_url     String?
  link_label   String?                @db.VarChar(120)
  sort_order   Int                    @default(0)
  is_active    Boolean                @default(true)
  active_from  DateTime?              @db.Timestamptz(6)
  active_until DateTime?              @db.Timestamptz(6)
  created_at   DateTime               @default(now()) @db.Timestamptz(6)
  updated_at   DateTime               @default(now()) @db.Timestamptz(6)

  @@index([placement, sort_order], map: "idx_announcement_placement_sort")
}

model marketing_popups {
  id                    String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title                 String                     @db.VarChar(255)
  body                  String
  image_url             String?
  cta_label             String?                    @db.VarChar(120)
  cta_url               String?
  delay_ms              Int                        @default(0)
  auto_close_ms         Int                        @default(0)
  frequency             marketing_popup_frequency  @default(ONCE_PER_SESSION)
  audience              marketing_popup_audience   @default(ALL)
  suggested_coupon_code String?                    @db.VarChar(80)
  sort_priority         Int                        @default(0)
  is_active             Boolean                    @default(true)
  active_from           DateTime?                  @db.Timestamptz(6)
  active_until          DateTime?                  @db.Timestamptz(6)
  created_at            DateTime                   @default(now()) @db.Timestamptz(6)
  updated_at            DateTime                   @default(now()) @db.Timestamptz(6)

  @@index([is_active, sort_priority], map: "idx_marketing_popups_active_priority")
}

model flash_sale_products {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id   String    @unique @db.Uuid
  sale_price   Decimal   @db.Decimal(10, 2)
  is_active    Boolean   @default(true)
  active_from  DateTime? @db.Timestamptz(6)
  active_until DateTime? @db.Timestamptz(6)
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  updated_at   DateTime  @default(now()) @db.Timestamptz(6)
  products     products  @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// Singleton-style settings row (use fixed id in app / seed).
model site_marketing_settings {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  first_visit_coupon_code String?  @db.VarChar(80)
  /// Homepage hero overlay eyebrow (small uppercase line).
  hero_overlay_eyebrow    String?  @db.VarChar(120)
  /// Homepage hero overlay main heading text.
  hero_overlay_heading    String?  @db.VarChar(255)
  /// Homepage hero overlay supporting subheading text.
  hero_overlay_subheading String?
  /// Homepage hero overlay CTA button label.
  hero_overlay_cta_label  String?  @db.VarChar(120)
  /// Homepage hero overlay CTA URL.
  hero_overlay_cta_href   String?  @db.VarChar(500)
  /// Homepage highlights block — small label above the carousel (CSS may uppercase).
  highlights_section_eyebrow  String? @db.VarChar(120)
  /// Homepage highlights block — main heading under the label.
  highlights_section_heading  String? @db.VarChar(255)
  /// Quick Links CMS: Privacy Policy page.
  privacy_page_title      String?  @db.VarChar(255)
  privacy_page_subtitle   String?  @db.VarChar(500)
  privacy_page_content    String?
  /// Quick Links CMS: Terms & Conditions page.
  terms_page_title        String?  @db.VarChar(255)
  terms_page_subtitle     String?  @db.VarChar(500)
  terms_page_content      String?
  /// Quick Links CMS: Return & Cancellation page.
  returns_page_title      String?  @db.VarChar(255)
  returns_page_subtitle   String?  @db.VarChar(500)
  returns_page_content    String?
  /// Quick Links CMS: FAQ page.
  faq_page_title          String?  @db.VarChar(255)
  faq_page_subtitle       String?  @db.VarChar(500)
  faq_page_content        String?
  /// Quick Links CMS: Contact page.
  contact_page_title      String?  @db.VarChar(255)
  contact_page_subtitle   String?  @db.VarChar(500)
  contact_page_content    String?
  /// Footer “Help & Support” block title
  help_support_title      String?  @db.VarChar(120)
  contact_address         String?
  contact_phone           String?  @db.VarChar(80)
  contact_email           String?  @db.VarChar(200)
  social_facebook_url     String?  @db.VarChar(500)
  social_twitter_url      String?  @db.VarChar(500)
  social_instagram_url    String?  @db.VarChar(500)
  social_linkedin_url     String?  @db.VarChar(500)
  updated_at              DateTime @default(now()) @db.Timestamptz(6)
}
